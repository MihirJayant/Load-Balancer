<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>

<AnchorPane style="-fx-background-color: linear-gradient(to bottom, #0C0F1A, #161B30);" 
             xmlns="http://javafx.com/javafx/11.0.2" 
             xmlns:fx="http://javafx.com/fxml/1" 
             fx:controller="com.mycompany.loadbalancer.LoadBalancerController" 
             prefWidth="900" prefHeight="600">

    <!-- Main UI Container -->
    <VBox alignment="CENTER" layoutX="80.0" layoutY="40.0" prefWidth="740" spacing="18"
          style="-fx-background-color: rgba(20, 25, 40, 0.95); -fx-background-radius: 15; -fx-padding: 30; 
                 -fx-effect: dropshadow(three-pass-box, rgba(0, 200, 255, 0.2), 10, 0, 0, 6); 
                 -fx-border-color: #00C8FF; -fx-border-width: 1.5px; -fx-border-radius: 15;">
        
        <Label style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #00C8FF;" text="Load Balancer File Manager" />

        <Label style="-fx-font-size: 14px; -fx-text-fill: #A1A1A1;" text="Select Scheduling Algorithm" />

        <ComboBox fx:id="algorithmComboBox" prefWidth="280"
                  style="-fx-font-size: 13px; -fx-padding: 6 10; 
                         -fx-background-color: linear-gradient(to bottom, #0C0F1A, #161B30);
                         -fx-text-fill: white; -fx-border-color: #00C8FF; -fx-border-radius: 8;">
            
        </ComboBox>

        <!-- Row 2 Buttons: Positioned with Upload Button in the Center -->
        <HBox alignment="CENTER" prefWidth="600" spacing="60">
            <Button fx:id="downloadFileBtn" onAction="#handleDownloadFile" text="Download"
                    style="-fx-background-color: #00C8FF; -fx-text-fill: black; -fx-font-size: 12px; 
                           -fx-background-radius: 15; -fx-padding: 8 20;" />

            <Button fx:id="uploadFileBtn" onAction="#handleUploadFile" text="Upload Files"
                    style="-fx-background-color: #0D6EFD; -fx-text-fill: white; -fx-font-size: 14px; 
                           -fx-background-radius: 15; -fx-padding: 10 24; -fx-border-color: transparent;" />

            <Button fx:id="deleteFileBtn" onAction="#handleDeleteFile" text="Delete"
                    style="-fx-background-color: #00C8FF; -fx-text-fill: black; -fx-font-size: 12px; 
                           -fx-background-radius: 15; -fx-padding: 8 20;" />
        </HBox>

        <TextArea fx:id="queueStatusText" prefHeight="120" prefWidth="600" editable="false" wrapText="true"
                  style="-fx-background-color: rgba(15, 20, 35, 0.9); -fx-text-fill: #1E90FF; 
                         -fx-font-size: 13px; -fx-border-color: #00C8FF; -fx-border-radius: 10;" />
    </VBox>

    <!-- Button Row 1: Wide-Spaced Buttons Below Queue Status -->
    <HBox alignment="CENTER" layoutX="90.0" layoutY="450.0" prefWidth="720" spacing="120">
        <Button fx:id="openTerminalBtn" onAction="#handleOpenTerminal" text="Terminal"
                style="-fx-background-color: #00C8FF; -fx-text-fill: black; -fx-font-size: 12px; 
                       -fx-background-radius: 15; -fx-padding: 8 20;" />
        
        <Button fx:id="processNextBtn" onAction="#handleProcessNextFile" text="Start Processing"
                style="-fx-background-color: #00C8FF; -fx-text-fill: black; -fx-font-size: 12px; 
                       -fx-background-radius: 15; -fx-padding: 8 20;" />

        <Button fx:id="checkHealthBtn" onAction="#handleCheckHealth" text="Health Check"
                style="-fx-background-color: #00C8FF; -fx-text-fill: black; -fx-font-size: 12px; 
                       -fx-background-radius: 15; -fx-padding: 8 20;" />
    </HBox>
</AnchorPane>
