<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane style="-fx-background-color: linear-gradient(to bottom, #0C0F1A, #161B30);" xmlns="http://javafx.com/javafx/22.0.2" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.javafxapplication1.RoleSelectionController">
    
    <!-- Main UI Container -->
    <VBox alignment="CENTER" layoutX="1.0" layoutY="1.0" prefHeight="486.0" prefWidth="635.0" spacing="25" style="-fx-background-color: rgba(20, 25, 40, 0.95); -fx-background-radius: 15;                   -fx-padding: 20; -fx-effect: dropshadow(three-pass-box, rgba(0, 200, 255, 0.2), 10, 0, 0, 6);                   -fx-border-color: #00C8FF; -fx-border-width: 1.5px; -fx-border-radius: 15;">
        
        <!-- Title -->
        <Label style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #00C8FF;" text="Select User Role" />
        
        <!-- Role Selection Buttons -->
        <VBox alignment="CENTER" spacing="20">
            <Button fx:id="standardUserBtn" onAction="#handleStandardUser" style="-fx-background-color: #00C8FF; -fx-text-fill: black;                             -fx-font-size: 14px; -fx-font-weight: bold;                            -fx-background-radius: 10; -fx-padding: 10 30;" text="Standard User" />

            <Button fx:id="adminUserBtn" onAction="#handleAdminUser" style="-fx-background-color: #16A085; -fx-text-fill: white;                             -fx-font-size: 14px; -fx-font-weight: bold;                            -fx-background-radius: 10; -fx-padding: 10 30;" text="Admin User" />
        </VBox>
        
        
        
    </VBox>
</AnchorPane>
