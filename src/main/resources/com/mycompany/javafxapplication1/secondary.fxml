<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.GridPane?>

<AnchorPane style="-fx-background-color: linear-gradient(to bottom, #0C0F1A, #161B30);" 
             xmlns="http://javafx.com/javafx/22.0.2" 
             xmlns:fx="http://javafx.com/fxml/1" 
             fx:controller="com.mycompany.javafxapplication1.SecondaryController">
    
    <!-- Main UI Container -->
    <VBox alignment="CENTER" layoutX="1.0" layoutY="1.0" prefHeight="500.0" prefWidth="650.0" spacing="20"
          style="-fx-background-color: rgba(20, 25, 40, 0.95); -fx-background-radius: 15; 
                 -fx-padding: 20; -fx-effect: dropshadow(three-pass-box, rgba(0, 200, 255, 0.2), 10, 0, 0, 6); 
                 -fx-border-color: #00C8FF; -fx-border-width: 1.5px; -fx-border-radius: 15;">
        
        <!-- Title -->
        <Label text="User Dashboard" 
               style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #00C8FF;" />
        
        <!-- Username Display -->
        <TextField fx:id="userTextField" promptText="Logged in as" editable="false" prefWidth="250"
                   style="-fx-background-color: rgba(15, 20, 35, 0.9); -fx-border-color: #00C8FF; 
                          -fx-border-radius: 10; -fx-padding: 8; -fx-font-size: 14px; -fx-text-fill: white;"/>
        
        <!-- User Table -->
        <TableView fx:id="dataTableView" prefHeight="150" prefWidth="500"
                   style="-fx-background-color: rgba(15, 20, 35, 0.9); -fx-border-color: #00C8FF; -fx-border-radius: 10;">
            <columns>
                <TableColumn fx:id="userColumn" text="Username" prefWidth="250"/>
                <TableColumn fx:id="passColumn" text="Hashed Password" prefWidth="250"/>
            </columns>
        </TableView>
        
        <!-- Update Password Section -->
        <PasswordField fx:id="newPasswordField" promptText="New Password" prefWidth="250"
                       style="-fx-background-color: rgba(15, 20, 35, 0.9); -fx-border-color: #00C8FF; 
                              -fx-border-radius: 10; -fx-padding: 8; -fx-font-size: 14px; -fx-text-fill: white;"/>
        
        <Button fx:id="updateUserBtn" text="Update Password" onAction="#handleUpdateUser"
                style="-fx-background-color: #00C8FF; -fx-text-fill: black; 
                       -fx-font-size: 14px; -fx-font-weight: bold;
                       -fx-background-radius: 10; -fx-padding: 10 30;"/>
        
        <!-- Delete Account & Logout Buttons -->
        <HBox spacing="20" alignment="CENTER">
            <Button fx:id="deleteUserBtn" text="Delete Account" onAction="#handleDeleteUser"
                    style="-fx-background-color: #A93226; -fx-text-fill: white; 
                           -fx-font-size: 14px; -fx-font-weight: bold;
                           -fx-background-radius: 10; -fx-padding: 10 30;"/>

            <Button fx:id="logoutBtn" text="Logout" onAction="#handleLogout"
                    style="-fx-background-color: #16A085; -fx-text-fill: white; 
                           -fx-font-size: 14px; -fx-font-weight: bold;
                           -fx-background-radius: 10; -fx-padding: 10 30;"/>
            
            <Button fx:id="selectFileBtn" text="Select File" onAction="#handleSelectFile"
                    style="-fx-background-color: #5D6D7E; -fx-text-fill: white; 
                           -fx-font-size: 14px; -fx-font-weight: bold;
                           -fx-background-radius: 10; -fx-padding: 10 30;"/>
        </HBox>
        
    </VBox>
</AnchorPane>
